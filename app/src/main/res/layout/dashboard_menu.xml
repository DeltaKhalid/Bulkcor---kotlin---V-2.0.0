<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="28dp">

    <!-- Vertical guideline at center to split left and right columns evenly -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineMid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <!-- ═══ ORDER (top-left) — top-LEFT corner rounded ═══ -->
    <FrameLayout
        android:id="@+id/cardOrder"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginEnd="3dp"
        android:background="@drawable/bg_card_tl"
        android:clickable="true"
        android:elevation="2dp"
        android:focusable="true"
        app:layout_constraintEnd_toStartOf="@+id/guidelineMid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/order_icon_desc"
                android:src="@android:drawable/ic_menu_send"
                app:tint="#2E7D32" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_order"
                android:textColor="#2E7D32"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ═══ PRE ORDER (top-right, staggered 65dp down) — top-RIGHT corner rounded ═══ -->
    <FrameLayout
        android:id="@+id/cardPreOrder"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginStart="3dp"
        android:layout_marginTop="65dp"
        android:background="@drawable/bg_card_tr"
        android:clickable="true"
        android:elevation="2dp"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guidelineMid"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/preorder_icon_desc"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="#2E7D32" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_pre_order"
                android:textColor="#2E7D32"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ═══ COLLECTION (bottom-left) — bottom-LEFT corner rounded ═══ -->
    <FrameLayout
        android:id="@+id/cardCollection"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="3dp"
        android:background="@drawable/bg_card_bl"
        android:clickable="true"
        android:elevation="2dp"
        android:focusable="true"
        app:layout_constraintEnd_toStartOf="@+id/guidelineMid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardOrder">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/collection_icon_desc"
                android:src="@android:drawable/ic_menu_save"
                app:tint="#2E7D32" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_collection"
                android:textColor="#2E7D32"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ═══ SALES RETURN (bottom-right) — bottom-RIGHT corner rounded ═══ -->
    <FrameLayout
        android:id="@+id/cardSalesReturn"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="3dp"
        android:background="@drawable/bg_card_br"
        android:clickable="true"
        android:elevation="2dp"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guidelineMid"
        app:layout_constraintTop_toBottomOf="@+id/cardPreOrder">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/salesreturn_icon_desc"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#2E7D32" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/menu_sales_return"
                android:textColor="#2E7D32"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Anchor spacer: forces ConstraintLayout wrap_content height to include cardSalesReturn bottom -->
    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/cardSalesReturn"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
