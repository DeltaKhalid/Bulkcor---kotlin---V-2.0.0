<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="#03245F">

        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="4">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconHome"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="Home"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="@color/nav_icon_tint" />

                <View
                    android:id="@+id/underlineHome"
                    android:layout_width="14dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#5CEBFF"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconAch"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="Achievement"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@color/nav_icon_tint" />

                <View
                    android:id="@+id/underlineAch"
                    android:layout_width="14dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#5CEBFF"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navReport"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconReport"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="Report"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/nav_icon_tint" />

                <View
                    android:id="@+id/underlineReport"
                    android:layout_width="14dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#5CEBFF"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navKnow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconKnow"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="Knowledge"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/nav_icon_tint" />

                <View
                    android:id="@+id/underlineKnow"
                    android:layout_width="14dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#5CEBFF"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>
